{
  "name": "yamatch-website",
  "version": "0.1.0",
  "private": true,
  "description": "Yamatch marketing one-pager — vanilla HTML/CSS/JS, no build step.",
  "scripts": {
    "build:css": "lightningcss --minify --bundle --targets '>= 0.5%' website/styles.css -o website/styles.min.css",
    "build": "npm run build:css",
    "predev": "npm run build:css",
    "prestart": "npm run build:css",
    "prepreview": "npm run build:css",
    "dev": "npx --yes live-server@1.2.2 website --port=8000 --no-browser --ignore=fonts/OFL.txt",
    "start": "npx --yes live-server@1.2.2 website --port=8000 --ignore=fonts/OFL.txt",
    "preview": "npx --yes live-server@1.2.2 website --port=8000"
  },
  "devDependencies": {
    "lightningcss-cli": "^1.32.0"
  }
}
