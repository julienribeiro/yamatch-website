# CSS minification output (generated by `npm run build:css` — never committed).
# In CI (.github/workflows/deploy.yml) it is built fresh before the Pages upload.
# Locally it is regenerated by the `predev` / `prestart` / `prepreview` npm hooks
# so live-server always sees a fresh build.
website/styles.min.css

